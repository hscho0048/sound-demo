# SoundCare Tauri/Web Control App
VITE_SOUNDCARE_API_BASE_URL=http://localhost:8080
VITE_USE_MOCK_API=true
VITE_NOTIFICATION_POLL_INTERVAL_MS=15000
VITE_APPLIANCE_MEASUREMENT_POLL_INTERVAL_MS=1000
VITE_DEVICE_AGENT_POLL_INTERVAL_MS=3000
VITE_DEFAULT_ROOM_ID=room-living
VITE_ENABLE_WEBSOCKET_PLACEHOLDER=false
# Serial 포트는 Tauri/Web이 직접 열지 않는다. ESP32-S3 USB Serial 통신은
# Appliance Controller Agent PC가 담당하므로 Serial 포트 변수는 두지 않는다.
