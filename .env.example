# SoundCare Tauri/Web Control App
VITE_SOUNDCARE_API_BASE_URL=http://localhost:8080
VITE_USE_MOCK_API=true
VITE_USE_API_FALLBACK=false
VITE_DEV_AUTH_ID_TOKEN=soundcare-tauri-local-dev
VITE_DEV_AUTH_EMAIL=tauri.local@soundcare.local
VITE_DEV_AUTH_DISPLAY_NAME=SoundCare Local Tester
VITE_NOTIFICATION_POLL_INTERVAL_MS=15000
VITE_DEFAULT_ROOM_ID=room-living
VITE_ENABLE_WEBSOCKET_PLACEHOLDER=false
# Tauri/Web은 ESP32-S3 제어 명령을 생성하지 않는다.
# ESP 제어와 Serial 통신은 별도 노트북의 Agent/firmware 실행 환경에서 담당한다.
